---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Habilidades">
  <div class="pt-24 pb-16">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-5xl font-bold text-center mb-6">
        Mis <span class="text-neon-blue">Habilidades</span>
      </h1>
      <p class="text-center text-gray-400 mb-16 text-lg">
        Tecnologías y herramientas que domino
      </p>

      <!-- Tech Skills con iconos reales -->
      <div class="mb-16">
        <h2 class="text-3xl font-bold mb-8 text-neon-blue text-center">
          Desarrollo Web
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
          <!-- HTML5 -->
          <div class="bg-dark-card p-6 rounded-xl border border-gray-700 hover:border-neon-blue transition-all text-center">
            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg" class="w-16 h-16 mx-auto mb-3" alt="HTML5" />
            <h3 class="font-semibold text-lg mb-2">HTML5</h3>
            <div class="w-full bg-gray-700 rounded-full h-2">
              <div class="bg-neon-blue h-2 rounded-full" style="width: 95%"></div>
            </div>
          </div>

          <!-- CSS3 -->
          <div class="bg-dark-card p-6 rounded-xl border border-gray-700 hover:border-neon-blue transition-all text-center">
            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-original.svg" class="w-16 h-16 mx-auto mb-3" alt="CSS3" />
            <h3 class="font-semibold text-lg mb-2">CSS3</h3>
            <div class="w-full bg-gray-700 rounded-full h-2">
              <div class="bg-neon-blue h-2 rounded-full" style="width: 90%"></div>
            </div>
          </div>

          <!-- JavaScript -->
          <div class="bg-dark-card p-6 rounded-xl border border-gray-700 hover:border-neon-blue transition-all text-center">
            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg" class="w-16 h-16 mx-auto mb-3" alt="JavaScript" />
            <h3 class="font-semibold text-lg mb-2">JavaScript</h3>
            <div class="w-full bg-gray-700 rounded-full h-2">
              <div class="bg-neon-blue h-2 rounded-full" style="width: 90%"></div>
            </div>
          </div>

          <!-- TypeScript -->
          <div class="bg-dark-card p-6 rounded-xl border border-gray-700 hover:border-neon-blue transition-all text-center">
            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg" class="w-16 h-16 mx-auto mb-3" alt="TypeScript" />
            <h3 class="font-semibold text-lg mb-2">TypeScript</h3>
            <div class="w-full bg-gray-700 rounded-full h-2">
              <div class="bg-neon-blue h-2 rounded-full" style="width: 85%"></div>
            </div>
          </div>

          <!-- Python -->
          <div class="bg-dark-card p-6 rounded-xl border border-gray-700 hover:border-neon-blue transition-all text-center">
            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg" class="w-16 h-16 mx-auto mb-3" alt="Python" />
            <h3 class="font-semibold text-lg mb-2">Python</h3>
            <div class="w-full bg-gray-700 rounded-full h-2">
              <div class="bg-neon-blue h-2 rounded-full" style="width: 85%"></div>
            </div>
          </div>

          <!-- Vue.js -->
          <div class="bg-dark-card p-6 rounded-xl border border-gray-700 hover:border-neon-blue transition-all text-center">
            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/vuejs/vuejs-original.svg" class="w-16 h-16 mx-auto mb-3" alt="Vue.js" />
            <h3 class="font-semibold text-lg mb-2">Vue.js</h3>
            <div class="w-full bg-gray-700 rounded-full h-2">
              <div class="bg-neon-blue h-2 rounded-full" style="width: 88%"></div>
            </div>
          </div>

          <!-- Astro -->
          <div class="bg-dark-card p-6 rounded-xl border border-gray-700 hover:border-neon-blue transition-all text-center">
            <svg class="w-16 h-16 mx-auto mb-3" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L15 8.5L22 9.5L17 14L18.5 21L12 17.5L5.5 21L7 14L2 9.5L9 8.5L12 2Z" fill="#BC52EE" stroke="#BC52EE" stroke-width="1.5"/>
            </svg>
            <h3 class="font-semibold text-lg mb-2">Astro</h3>
            <div class="w-full bg-gray-700 rounded-full h-2">
              <div class="bg-neon-blue h-2 rounded-full" style="width: 85%"></div>
            </div>
          </div>

          <!-- Tailwind CSS -->
          <div class="bg-dark-card p-6 rounded-xl border border-gray-700 hover:border-neon-blue transition-all text-center">
            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/tailwindcss/tailwindcss-original.svg" class="w-16 h-16 mx-auto mb-3" alt="Tailwind CSS" />
            <h3 class="font-semibold text-lg mb-2">Tailwind CSS</h3>
            <div class="w-full bg-gray-700 rounded-full h-2">
              <div class="bg-neon-blue h-2 rounded-full" style="width: 92%"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Roblox & Lua Section -->
      <div class="mb-16">
        <h2 class="text-3xl font-bold mb-8 text-neon-blue text-center">
          Roblox Studio & Lua
        </h2>
        
        <div class="bg-gradient-to-br from-dark-card to-dark p-8 rounded-xl border border-neon-blue/30">
          <div class="flex items-center gap-4 mb-8 flex-wrap justify-center">
            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/roblox/roblox-original.svg" class="w-20 h-20" alt="Roblox Studio" />
            <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/lua/lua-original.svg" class="w-20 h-20" alt="Lua" />
          </div>
          
          <div class="grid md:grid-cols-2 gap-8">
            <div>
              <h3 class="text-xl font-bold text-neon-blue mb-4">🎮 Experiencia en Roblox</h3>
              <ul class="space-y-3">
                <li class="flex items-start gap-2">
                  <span class="text-neon-blue">✓</span>
                  <span>Desarrollo de juegos completos con Lua</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-neon-blue">✓</span>
                  <span>Creación de GUIs interactivas y sistemas de UI</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-neon-blue">✓</span>
                  <span>Sistemas de guardado con DataStore</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-neon-blue">✓</span>
                  <span>Scripting de eventos y RemoteEvents/RemoteFunctions</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-neon-blue">✓</span>
                  <span>Sistemas de combate y habilidades</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-neon-blue">✓</span>
                  <span>Optimización de rendimiento y reducción de lag</span>
                </li>
              </ul>
            </div>
            
            <div>
              <h3 class="text-xl font-bold text-neon-blue mb-4">🚀 Proyectos destacados</h3>
              <div class="space-y-4">
                <div class="bg-dark p-4 rounded-lg">
                  <h4 class="font-bold text-neon-blue">Sistema de RPG</h4>
                  <p class="text-sm text-gray-400">Sistema completo de niveles, habilidades y clases</p>
                </div>
                <div class="bg-dark p-4 rounded-lg">
                  <h4 class="font-bold text-neon-blue">Tienda virtual</h4>
                  <p class="text-sm text-gray-400">Sistema de compras con GamePasses y Developer Products</p>
                </div>
                <div class="bg-dark p-4 rounded-lg">
                  <h4 class="font-bold text-neon-blue">Minijuegos</h4>
                  <p class="text-sm text-gray-400">Colección de minijuegos multijugador</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Soft Skills -->
      <div>
        <h2 class="text-3xl font-bold mb-8 text-neon-blue text-center">
          Soft Skills
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { name: 'Trabajo en equipo', icon: '🤝' },
            { name: 'Comunicación', icon: '💬' },
            { name: 'Resolución de problemas', icon: '🧩' },
            { name: 'Aprendizaje rápido', icon: '⚡' }
          ].map(skill => (
            <div class="bg-dark-card p-4 rounded-xl text-center border border-gray-700">
              <div class="text-3xl mb-2">{skill.icon}</div>
              <p class="font-semibold">{skill.name}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>