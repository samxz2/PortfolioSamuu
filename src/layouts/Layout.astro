---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | SamuDev</title>
  <meta name="description" content="Portafolio profesional de SamuDev - Desarrollador Full Stack" />
  <link rel="stylesheet" href="/src/styles/global.css" />
</head>
<body class="bg-bg-primary">
  <!-- Background subtle gradient -->
  <div class="fixed inset-0 -z-10">
    <div class="absolute inset-0 bg-gradient-to-br from-bg-primary via-bg-secondary to-bg-tertiary"></div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-secondary/5 rounded-full blur-3xl"></div>
  </div>

  <!-- Navigation -->
  <nav class="fixed top-0 w-full z-50 bg-black/90 backdrop-blur-md border-b border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <a href="/" class="text-2xl font-display font-bold gradient-text">
          SamuDev
        </a>
        
        <div class="hidden md:flex items-center space-x-8">
          <a href="#inicio" class="text-text-secondary hover:text-text-primary transition-colors duration-300">Inicio</a>
          <a href="#sobre-mi" class="text-text-secondary hover:text-text-primary transition-colors duration-300">Sobre Mí</a>
          <a href="#habilidades" class="text-text-secondary hover:text-text-primary transition-colors duration-300">Habilidades</a>
          <a href="#contacto" class="text-text-secondary hover:text-text-primary transition-colors duration-300">Contacto</a>
        </div>
        
        <a href="#contacto" class="hidden md:block px-5 py-2 bg-primary hover:bg-primary-dark text-white text-sm font-semibold rounded-lg transition-all">
          Contratar
        </a>

        <button id="menuBtn" class="md:hidden text-text-primary">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <div id="mobileMenu" class="hidden md:hidden bg-bg-secondary border-t border-border">
      <div class="px-4 py-3 space-y-2">
        <a href="#inicio" class="block py-2 text-text-secondary hover:text-text-primary">Inicio</a>
        <a href="#sobre-mi" class="block py-2 text-text-secondary hover:text-text-primary">Sobre Mí</a>
        <a href="#habilidades" class="block py-2 text-text-secondary hover:text-text-primary">Habilidades</a>
        <a href="#contacto" class="block py-2 text-text-secondary hover:text-text-primary">Contacto</a>
        <a href="#contacto" class="block py-2 text-primary font-semibold">Contratar</a>
      </div>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="border-t border-border py-12 mt-20 bg-bg-secondary/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8">
        <div>
          <h3 class="text-2xl font-display font-bold gradient-text mb-4">SamuDev</h3>
          <p class="text-text-tertiary text-sm">Transformando ideas en código, creando experiencias digitales excepcionales.</p>
        </div>
        <div>
          <h4 class="font-semibold text-text-primary mb-4">Enlaces Rápidos</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="#inicio" class="text-text-tertiary hover:text-primary transition-colors">Inicio</a></li>
            <li><a href="#sobre-mi" class="text-text-tertiary hover:text-primary transition-colors">Sobre Mí</a></li>
            <li><a href="#habilidades" class="text-text-tertiary hover:text-primary transition-colors">Habilidades</a></li>
            <li><a href="#contacto" class="text-text-tertiary hover:text-primary transition-colors">Contacto</a></li>
          </ul>
        </div>
        <div>
  </footer>

  <script>
    const menuBtn = document.getElementById('menuBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    
    menuBtn?.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });

    document.querySelectorAll('#mobileMenu a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
      });
    });
  </script>
</body>
</html>